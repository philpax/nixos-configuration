{
  "env": {
    "PATH": "$(PATH):$(HOME)/.local/bin"
  },
  "apps": [
    {
      "name": "Desktop",
      "image-path": "desktop.png"
    },
    {
      "name": "Steam (gamescope 1440p)",
      "image-path": "steam.png",
      "cmd": "/run/current-system/sw/bin/sunshine-gamescope-stream start steam",
      "prep-cmd": [
        {
          "do": "",
          "undo": "/run/current-system/sw/bin/sunshine-gamescope-stream stop"
        }
      ]
    },
    {
      "name": "Prism Launcher (gamescope 1440p)",
      "image-path": "/run/current-system/sw/share/icons/hicolor/256x256/apps/org.prismlauncher.PrismLauncher.png",
      "cmd": "/run/current-system/sw/bin/sunshine-gamescope-stream start prism",
      "prep-cmd": [
        {
          "do": "",
          "undo": "/run/current-system/sw/bin/sunshine-gamescope-stream stop"
        }
      ]
    }
  ]
}
