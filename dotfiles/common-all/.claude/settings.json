{
  "env": {
    "CLAUDE_CODE_SUPPRESS_SESSION_ATTRIBUTION": "1",
    "CLAUDE_CODE_SCROLL_SPEED": "6"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "model": "claude-fable-5[1m]",
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": false,
    "superpowers@claude-plugins-official": false,
    "ralph-loop@claude-plugins-official": true,
    "ida-pro-mcp@mrexodia": true,
    "ed3d-plan-and-execute@ed3d-plugins": true,
    "ed3d-house-style@ed3d-plugins": true
  },
  "extraKnownMarketplaces": {
    "mrexodia": {
      "source": {
        "source": "github",
        "repo": "mrexodia/claude-marketplace"
      }
    },
    "ed3d-plugins": {
      "source": {
        "source": "git",
        "url": "https://github.com/ed3dai/ed3d-plugins.git"
      }
    }
  },
  "effortLevel": "medium",
  "awaySummaryEnabled": false,
  "tui": "fullscreen",
  "skipDangerousModePermissionPrompt": true,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true
