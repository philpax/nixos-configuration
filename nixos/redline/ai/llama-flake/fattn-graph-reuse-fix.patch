+// Per-call scratch shards for graph-external accesses (no owner identity at
+// the buffer interface). The shard structs only need to live for the duration
+// of the call: they are plain views over the same underlying device memory.
+struct ggml_backend_meta_scratch_shards {
+    ggml_backend_meta_simple_tensor_container & stc;
+
+    explicit ggml_backend_meta_scratch_shards(size_t n_bufs) : stc(acquire(n_bufs)) {
+        // REFACTOR (local, experimental): the pools are PERSISTENT across
+        // calls — graph-external accesses overwhelmingly target the same
+        // (reused-graph) tensor structs every step, so re-creating their
+        // shards per call costs ~0.4 ms each (measured ~12 calls/token => the
+        // dominant decode overhead). Entries are identity-validated on lookup
+        // (see ensure), which is sound here because each pool has a single
+        // owner thread. Compact only when the struct arena nears capacity.
+        bool needs_compact = false;
+        for (ggml_context_ptr & c : stc.ctxs) {
+            if (ggml_used_mem(c.get()) > 3*ggml_get_mem_size(c.get())/4) {
+                needs_compact = true;
+                break;
+            }
+        }
+        if (needs_compact) {
+            for (ggml_context_ptr & c : stc.ctxs) {
+                ggml_reset(c.get());
+            }
+            stc.simple_tensors.clear();
+            stc.identities.clear();
+        }
+    }
+
+
+    // Reusable thread-local pools, reset at the start of each call. The shard
+    // structs only need to outlive the enclosing buffer-interface call.
+    static ggml_backend_meta_simple_tensor_container & acquire(size_t n_bufs) {
+        static thread_local std::map<size_t, ggml_backend_meta_simple_tensor_container> registry;
+        auto it = registry.find(n_bufs);
+        if (it == registry.end()) {
+            const ggml_init_params params = {
+                /*.mem_size   =*/ 16*1024*ggml_tensor_overhead(),
+                /*.mem_buffer =*/ nullptr,
+                /*.no_alloc   =*/ true,
+            };
+            it = registry.emplace(n_bufs, ggml_backend_meta_simple_tensor_container(params, (int) n_bufs)).first;
+            it->second.validate_identity = true;
+        }
+        return it->second;
+    }
+
+    ggml_tensor * get(const ggml_tensor * tensor, size_t index) {
+        return ggml_backend_meta_simple_tensor_ensure(stc, (ggml_tensor *) tensor, index);
+    }
+};
